# Скопируйте в .env и заполните. Файл .env НЕ коммитится.

ENVIRONMENT=local
DEBUG=true
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# PostgreSQL (значения используются и docker-compose, и приложением)
POSTGRES_USER=aicoach
POSTGRES_PASSWORD=aicoach
POSTGRES_DB=aicoach
DATABASE_URL=postgresql+asyncpg://aicoach:aicoach@db:5432/aicoach

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-please-32-chars-minimum
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=30

# Провайдеры входа
TELEGRAM_BOT_TOKEN=
GOOGLE_CLIENT_ID=

# Шифрование чувствительных полей (этапы 4+)
FIELD_ENCRYPTION_KEY=

# AI (этапы 2/4/5)
OPENAI_API_KEY=

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_BUCKET=ai-coach
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

DB_PORT=55432
REDIS_PORT=56379
API_PORT=18000
MINIO_PORT=59000
MINIO_CONSOLE_PORT=59001
WEB_PORT=8081